<%# Shared form used by both new and edit pages %>
<%= form_with model: book do |form| %>
    <%# Checks for validation errors %>
    <% if book.errors.any? %>
        <div>
            <h2><%= pluralize(book.errors.count, "error") %> prevented this book from saving:</h2>
            <ul>
                <% book.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                <% end %>
            </ul>
        </div>
    <% end %>

    <%# Title input %>
    <div>
        <%= form.label :title %>
        <%= form.text_field :title %>
    </div>

    <%# Author Input %>
    <div>
        <%= form.label :author %>
        <%= form.text_field :author %>
    </div>

    <%# Genre Input %>
    <div>
        <%= form.label :genre %>
        <%= form.text_field :genre %>
    </div>

    <%# Short Description Input %>
    <div>
        <%= form.label :short_description %>
        <%= form.text_field :short_description %>
    </div>

    <%# Submit Button %>
    <div>
        <%= form.submit %>
    </div>
<% end %>
